{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "scripts": {
    "setup": "npx prisma db push && npx ts-node prisma/seed.ts && npm run catalog",
    "catalog": "ts-node src/importGameStoreCatalog.ts",
    "lizardbyte": "ts-node src/importLizardByteGameDB.ts",
    "genres": "ts-node src/backfillGenres.ts",
    "covers": "ts-node src/backfillCovers.ts",
    "platforms": "ts-node src/backfillPlatforms.ts",
    "critic-scores": "ts-node src/backfillCriticScores.ts",
    "dev": "nodemon src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/src/server.js",
    "start:ts": "ts-node src/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
