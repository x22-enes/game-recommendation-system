PORT=5000
NODE_ENV=production
DATABASE_URL="file:./dev.db"
JWT_SECRET="replace_with_at_least_32_random_characters"

# Same-domain deploy can leave FRONTEND_URL empty. If frontend is hosted separately,
# add its exact origin. Multiple origins: "https://yourdomain.com,https://www.yourdomain.com"
FRONTEND_URL="https://yourdomain.com"

IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""
RAWG_API_KEY=""
USE_LIVE_APIS=false
