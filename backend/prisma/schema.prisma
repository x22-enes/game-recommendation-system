generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  email          String?        @unique
  emailVerified  Boolean        @default(false)
  passwordHash   String
  favoriteGenres String?        // Stored as JSON string
  avatarUrl      String?
  steamProfileUrl String?
  library        UserGame[]
  wishlist       WishlistItem[]
  comments       GameComment[]
  commentLikes   CommentLike[]
  emailVerificationCodes EmailVerificationCode[]
}

model EmailVerificationCode {
  id        String   @id @default(uuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Game {
  id          String         @id @default(uuid())
  title       String
  genres      String?        // Stored as JSON string
  platforms   String?        // Stored as JSON string
  description String?
  coverUrl    String?
  source      String?        // e.g., 'rawg', 'igdb', 'custom'
  criticScore Int?
  criticSource String?
  library     UserGame[]
  wishlist    WishlistItem[]
  storePrices StorePrice[]
  comments    GameComment[]

  @@index([title])
  @@index([source])
  @@index([criticScore])
}

model UserGame {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  status    String?  // 'Playing', 'Completed', 'Plan to Play'
  rating    Float?   // CHANGED TO FLOAT TO ALLOW 0.5 RATINGS!
  user      User     @relation(fields: [userId], references: [id])
  game      Game     @relation(fields: [gameId], references: [id])

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@index([status])
  @@index([rating])
}

model WishlistItem {
  id     String @id @default(uuid())
  userId String
  gameId String
  user   User   @relation(fields: [userId], references: [id])
  game   Game   @relation(fields: [gameId], references: [id])

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model StorePrice {
  id        String @id @default(uuid())
  gameId    String
  storeName String
  price     Float
  url       String
  source    String // e.g., 'cheapshark'
  game      Game   @relation(fields: [gameId], references: [id])

  @@index([gameId])
  @@index([gameId, price])
  @@index([source])
  @@index([storeName])
}

model GameComment {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  body      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  game      Game     @relation(fields: [gameId], references: [id])
  parent    GameComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   GameComment[] @relation("CommentReplies")
  likes     CommentLike[]

  @@index([gameId, createdAt])
  @@index([parentId, createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  user      User        @relation(fields: [userId], references: [id])
  comment   GameComment @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId])
  @@index([commentId])
}
